# Path where Playwright saves/restores cookies + storage (keep secret; gitignored via .secrets/)
PLAYWRIGHT_STORAGE_STATE=./.secrets/cursor-auth.json

# Comma-separated calendar months (invoice date interpreted in TZ below)
INVOICE_MONTHS=2025-01,2025-02,2025-03

# Optional: one month per line, # for comments (see months.example.txt)
# INVOICE_MONTHS_FILE=./months.txt

# IANA timezone for mapping invoice timestamps to YYYY-MM
TZ=UTC

# PDF output directory
OUTPUT_DIR=./invoices

# After auth works, you can set true for unattended runs
HEADLESS=true

# Optional overrides
CURSOR_BILLING_URL=https://cursor.com/dashboard/billing
CURSOR_AUTH_START_URL=https://cursor.com/dashboard
